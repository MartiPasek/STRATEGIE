# Environment
.env
.env.*
!.env.example

# Database backups (Phase 7.11) -- obsahuji PII, emaily, diář.
# Nikdy do gitu. Kopiruj rucne na OneDrive / externi disk.
backups/
*.dump
*.sql.gz

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment
.venv/
venv/
env/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build artifacts
*.egg-info/
build/
dist/

# Logs
*.log
logs/

# Jednorazove dev / commit / push helpery (nejsou soucasti produkcniho
# kodu, vyrabeny ad-hoc pri vyvoji a zahazovany po pouziti).
# Soubor dev.ps1 v gitu ZUSTAVA -- to je hlavni dev launcher.
scripts/commit_*.ps1
scripts/push_phase*.ps1
scripts/test_*.ps1
scripts/cleanup_*.ps1
scripts/_*.py

# Commit message drafts (pouzivany v commit scripts pres Set-Content)
.git_commit_msg*.txt

# Generovane dokumenty (PDF runbooky, schemata) -- generuji se ad-hoc,
# verzuji se zdrojovem skriptem (make_runbook.py) ne vystupem.
*.pdf

# Storage adresare -- avatary person v projektu (default Avatary/), pripadne
# i dokumenty pokud nekdo prepise DOCUMENTS_STORAGE_DIR na lokalni cestu.
# Soubory jsou per-instance dat, do gitu nepatri.
Avatary/
Dokumenty/
